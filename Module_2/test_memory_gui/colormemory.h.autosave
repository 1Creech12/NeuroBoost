#ifndef COLORMEMORY_H
#define COLORMEMORY_H

#include <QMainW>

QT_BEGIN_NAMESPACE
namespace Ui {
class ColorMemory;
}
QT_END_NAMESPACE

class ColorMemory : public QMainWindow
{
    Q_OBJECT

public:
    explicit ColorMemory(QWidget *parent = nullptr);
    ~ColorMemory() override;
    
    void addColor(); // добавляет цвет в последовательность
    bool isCorrect(int index, const QString& playerColor); //  проверяет правильно ли игрок угадал последовательность
    const QVector<QString>& getSequence() const {return sequence;}
    void game();
private slots:
    void on_redButton_clicked();
    
private:
    Ui::ColorMemory *ui;
    QVector<QString> sequence; // последовательность
};
#endif // COLORMEMORY_H
